pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-sa
  containers:
  - name: jnlp
    image: jenkins/inbound-agent:latest
    tty: true

  - name: python
    image: python:3.12-slim
    command: ["/bin/sh"]
    tty: true

  - name: docker
    image: docker:24.0.5-dind
    securityContext:
      privileged: true
    tty: true
    args:
      - --host=unix:///var/run/docker.sock
    volumeMounts:
      - name: docker-graph-storage
        mountPath: /var/lib/docker

  volumes:
  - name: docker-graph-storage
    emptyDir: {}
'''
        }
    }

    environment {
        AWS_REGION           = "ap-southeast-1"
        ECR_URI              = "408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680"
        LAMBDA_FUNCTION_NAME = "aqi-prediction-lambda"
        S3_BUCKET            = "iot-bme680-data-lake-prod"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ── Stage 1: Checkout ──────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Branch : ${env.GIT_BRANCH}"
                echo "   Commit : ${env.GIT_COMMIT}"
            }
        }

        // ── Stage 2: Validate ──────────────────────────────────────
        stage('Validate') {
            steps {
                script {
                    def required = ['lambda/Dockerfile', 'lambda/app.py']
                    for (f in required) {
                        if (!fileExists(f)) {
                            error "❌ File bắt buộc không tồn tại: ${f}"
                        }
                    }
                    echo "✅ Tất cả files bắt buộc đều có mặt"
                }
            }
        }

        // ── Stage 3: Pull model artifacts từ S3 ───────────────────
        // IRSA (jenkins-sa) có quyền S3 — không cần credentials binding
        stage('Pull Model Artifacts') {
            steps {
                container('docker') {
                    sh """
                        apk add --no-cache aws-cli python3 py3-pip
                        pip install joblib scikit-learn --quiet --only-binary=:all:

                        echo "📦 Pulling model artifacts từ S3..."
                        aws s3 cp s3://${S3_BUCKET}/models/latest/model.pkl  ./model.pkl  --region ${AWS_REGION}
                        aws s3 cp s3://${S3_BUCKET}/models/latest/scaler.pkl ./scaler.pkl --region ${AWS_REGION}

                        echo "✅ model.pkl  : \$(du -sh model.pkl  | cut -f1)"
                        echo "✅ scaler.pkl : \$(du -sh scaler.pkl | cut -f1)"

                        python3 -c "
import joblib, sys
try:
    m = joblib.load('model.pkl')
    s = joblib.load('scaler.pkl')
    assert hasattr(m, 'predict'),   'model.pkl không có method predict'
    assert hasattr(s, 'transform'), 'scaler.pkl không có method transform'
    print(f'✅ Artifacts validated | model={type(m).__name__} | scaler={type(s).__name__}')
except Exception as e:
    print(f'❌ Artifact validation failed: {e}')
    sys.exit(1)
"
                        # Copy vào lambda/ để nằm trong Docker build context
                        cp model.pkl  lambda/model.pkl
                        cp scaler.pkl lambda/scaler.pkl
                        echo "✅ Copied artifacts → lambda/"
                    """
                }
            }
        }

        // ── Stage 4: Build & Push Docker image ────────────────────
        stage('Build & Push') {
            steps {
                container('docker') {
                    script {
                        def imageTag = "commit-${env.GIT_COMMIT.take(7)}"

                        sh """
                            apk add --no-cache aws-cli

                            echo "🔐 Logging in to ECR..."
                            aws ecr get-login-password --region ${AWS_REGION} \
                                | docker login --username AWS --password-stdin ${ECR_URI}
                                
                            echo "Setup multi-platform build..."
                            docker run --rm --privileged multiarch/qemu-user-static --reset -p yes || true
                            docker buildx create --name arm64builder --driver docker-container --use || true
                            docker buildx inspect --bootstrap

                            MLFLOW_RUN_ID=$(cat .mlflow_run_id)
                            echo "🐳 Building Docker image for linux/arm64..."
                            docker buildx build \\
                                --platform linux/arm64 \\
                                --load \\
                                --build-arg BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) \\
                                --build-arg GIT_COMMIT=${GIT_COMMIT} \\
                                --label mlflow.run_id=${MLFLOW_RUN_ID} \\
                                -t ${ECR_URI}:${IMAGE_TAG}-arm64 \\
                                -t ${ECR_URI}:build-${BUILD_NUMBER}-arm64 \\
                                lambda/
                                 
                            echo "✅ Build complete: ${ECR_URI}:${IMAGE_TAG}-arm64"
                            echo "   MLflow run_id : ${MLFLOW_RUN_ID}"

                            echo "🧪 Smoke test..."
                            docker run --rm \
                                --entrypoint python \
                                ${ECR_URI}:${imageTag} \
                                -c "
import joblib, sys
model  = joblib.load('/var/task/model.pkl')
scaler = joblib.load('/var/task/scaler.pkl')
import numpy as np
sample = scaler.transform([[25.0, 60.0, 1013.0, 50000.0]])
pred   = model.predict(sample)
assert pred[0] in [-1, 1], 'predict() phải trả về -1 hoặc 1'
print(f'✅ Smoke test passed | pred={pred[0]}')
"

                            echo "🚀 Pushing to ECR..."
                            docker push ${ECR_URI}:${imageTag}
                            docker push ${ECR_URI}:latest
                            echo "✅ Pushed: ${ECR_URI}:${imageTag}"
                        """

                        // Lưu imageTag để stage deploy dùng
                        env.IMAGE_TAG = imageTag
                    }
                }
            }
        }

        // ── Stage 5: Deploy to Lambda ──────────────────────────────
        stage('Deploy to Lambda') {
            steps {
                container('docker') {
                    sh """
                        apk add --no-cache aws-cli

                        echo "⚡ Updating Lambda: ${LAMBDA_FUNCTION_NAME}..."
                        aws lambda update-function-code \
                            --function-name ${LAMBDA_FUNCTION_NAME} \
                            --image-uri     ${ECR_URI}:${env.IMAGE_TAG} \
                            --region        ${AWS_REGION}

                        echo "⏳ Waiting for update to complete..."
                        aws lambda wait function-updated \
                            --function-name ${LAMBDA_FUNCTION_NAME} \
                            --region        ${AWS_REGION}

                        echo "✅ Lambda updated → ${ECR_URI}:${env.IMAGE_TAG}"
                    """
                }
            }
        }

        // ── Stage 6: Verify Lambda ─────────────────────────────────
        stage('Verify Lambda') {
            steps {
                container('docker') {
                    sh """
                        apk add --no-cache aws-cli python3

                        echo "🔍 Verifying Lambda deployment..."
                        aws lambda invoke \
                            --function-name ${LAMBDA_FUNCTION_NAME} \
                            --region        ${AWS_REGION} \
                            --payload       '{"body": "{\\"T\\": 25.0, \\"H\\": 60.0, \\"P\\": 1013.0, \\"G\\": 50000.0}"}' \
                            --cli-binary-format raw-in-base64-out \
                            /tmp/lambda_response.json

                        echo "📋 Lambda response:"
                        cat /tmp/lambda_response.json

                        python3 -c "
import json, sys
with open('/tmp/lambda_response.json') as f:
    resp = json.load(f)
status = resp.get('statusCode', 500)
if status != 200:
    print(f'❌ statusCode={status}')
    sys.exit(1)
body = json.loads(resp.get('body', '{}'))
print(f'✅ Verify passed | is_anomaly={body.get(\"is_anomaly\")} | score={body.get(\"decision_score\")}')
"
                    """
                }
            }
        }
    }

    post {
        success {
            echo """
╔══════════════════════════════════════════════╗
║  ✅  DEPLOYMENT SUCCESSFUL                   ║
╠══════════════════════════════════════════════╣
║  Image  : ${ECR_URI}:${env.IMAGE_TAG}
║  Lambda : ${LAMBDA_FUNCTION_NAME}
║  Build  : #${BUILD_NUMBER}
╚══════════════════════════════════════════════╝
"""
        }
        failure {
            echo "❌ Pipeline failed — xem logs bên trên để debug"
        }
        always {
            sh "rm -f lambda/model.pkl lambda/scaler.pkl model.pkl scaler.pkl || true"
            echo "🧹 Workspace cleanup complete"
        }
    }
}

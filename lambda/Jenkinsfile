pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-sa
  containers:
  - name: jnlp
    image: jenkins/inbound-agent:latest
    tty: true

  - name: python
    image: python:3.12-slim
    command: ["/bin/sh"]
    tty: true

  - name: docker
    image: docker:24.0.5-dind
    securityContext:
      privileged: true
    tty: true
    args:
      - --host=unix:///var/run/docker.sock
    volumeMounts:
      - name: docker-graph-storage
        mountPath: /var/lib/docker

  volumes:
  - name: docker-graph-storage
    emptyDir: {}
'''
        }
    }

    environment {
        AWS_REGION           = "ap-southeast-1"
        ECR_URI              = "408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680"
        LAMBDA_FUNCTION_NAME = "aqi-prediction-lambda"
        S3_BUCKET            = "iot-bme680-data-lake-prod"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ── Stage 1: Checkout ──────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Branch : ${env.GIT_BRANCH}"
                echo "   Commit : ${env.GIT_COMMIT}"
            }
        }

        // ── Stage 2: Validate ──────────────────────────────────────
        stage('Validate') {
            steps {
                script {
                    def required = ['lambda/Dockerfile', 'lambda/app.py']
                    for (f in required) {
                        if (!fileExists(f)) {
                            error "❌ File bắt buộc không tồn tại: ${f}"
                        }
                    }
                    echo "✅ Tất cả files bắt buộc đều có mặt"
                }
            }
        }

        // ── Stage 3: Pull model artifacts từ S3 ───────────────────
        // Pull bằng container docker (có aws-cli), validate bằng container python
        stage('Pull Model Artifacts') {
            steps {
                // Bước 1: Pull từ S3 — dùng container docker vì có IRSA + aws-cli
                container('docker') {
                    sh '''
                        apk add --no-cache aws-cli

                        echo "📦 Pulling model artifacts từ S3..."
                        aws s3 cp s3://iot-bme680-data-lake-prod/models/latest/model.pkl  ./model.pkl  --region ap-southeast-1
                        aws s3 cp s3://iot-bme680-data-lake-prod/models/latest/scaler.pkl ./scaler.pkl --region ap-southeast-1

                        echo "✅ model.pkl  : $(du -sh model.pkl  | cut -f1)"
                        echo "✅ scaler.pkl : $(du -sh scaler.pkl | cut -f1)"

                        cp model.pkl  lambda/model.pkl
                        cp scaler.pkl lambda/scaler.pkl
                        echo "✅ Copied artifacts vào lambda/"
                    '''
                }
                // Bước 2: Validate — dùng container python (có pip, wheel sẵn cho linux/amd64)
                container('python') {
                    sh '''
                        # dill: model.pkl được serialize bằng dill
                        # scikit-learn==1.6.1: khớp version lúc train để tránh InconsistentVersionWarning
                        pip install "scikit-learn==1.6.1" joblib dill --quiet

                        python3 -c "
import warnings, joblib, sys
# Suppress version warning sau khi đã pin đúng version
warnings.filterwarnings('ignore', category=UserWarning)
try:
    m = joblib.load('model.pkl')
    s = joblib.load('scaler.pkl')
    assert hasattr(m, 'predict'),   'model.pkl không có method predict'
    assert hasattr(s, 'transform'), 'scaler.pkl không có method transform'
    print(f'Artifacts validated | model={type(m).__name__} | scaler={type(s).__name__}')
except Exception as e:
    print(f'Artifact validation failed: {e}')
    sys.exit(1)
"
                    '''
                }
            }
        }

        // ── Stage 4: Build & Push Docker image ────────────────────
        // Dùng script{} để define imageTag trong Groovy,
        // sau đó truyền xuống shell qua biến env
        stage('Build & Push') {
            steps {
                container('docker') {
                    script {
                        // Groovy: định nghĩa tag từ git commit
                        env.IMAGE_TAG = "commit-${env.GIT_COMMIT.take(7)}"

                        // Single-quote string → shell xử lý hoàn toàn, không có Groovy interpolation
                        // Dùng env.IMAGE_TAG (đã set ở trên) để truyền vào shell qua environment block
                        sh '''
                            apk add --no-cache aws-cli

                            echo "🔐 Logging in to ECR..."
                            aws ecr get-login-password --region ap-southeast-1 \
                                | docker login --username AWS --password-stdin 408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680

                            echo "⚙️  Setup multi-platform buildx..."
                            docker run --rm --privileged multiarch/qemu-user-static --reset -p yes || true
                            docker buildx create --name arm64builder --driver docker-container --use || true
                            docker buildx inspect --bootstrap

                            echo "🐳 Building Docker image for linux/arm64..."
                            docker buildx build \
                                --platform linux/arm64 \
                                --load \
                                --build-arg BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) \
                                --build-arg GIT_COMMIT=$GIT_COMMIT \
                                -t 408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:$IMAGE_TAG \
                                -t 408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:latest \
                                lambda/

                            echo "🧪 Smoke test..."
                            docker run --rm \
                                --entrypoint python \
                                408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:$IMAGE_TAG \
                                -c "
import joblib, sys
model  = joblib.load('/var/task/model.pkl')
scaler = joblib.load('/var/task/scaler.pkl')
import numpy as np
sample = scaler.transform([[25.0, 60.0, 1013.0, 50000.0]])
pred   = model.predict(sample)
assert pred[0] in [-1, 1], 'predict() must return -1 or 1'
print(f'Smoke test passed | pred={pred[0]}')
"

                            echo "🚀 Pushing to ECR..."
                            docker push 408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:$IMAGE_TAG
                            docker push 408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:latest
                            echo "✅ Pushed: $IMAGE_TAG"
                        '''
                    }
                }
            }
        }

        // ── Stage 5: Deploy to Lambda ──────────────────────────────
        stage('Deploy to Lambda') {
            steps {
                container('docker') {
                    sh '''
                        apk add --no-cache aws-cli

                        echo "⚡ Updating Lambda: aqi-prediction-lambda..."
                        aws lambda update-function-code \
                            --function-name aqi-prediction-lambda \
                            --image-uri     408279620390.dkr.ecr.ap-southeast-1.amazonaws.com/iot-bme680:$IMAGE_TAG \
                            --region        ap-southeast-1

                        echo "⏳ Waiting for update to complete..."
                        aws lambda wait function-updated \
                            --function-name aqi-prediction-lambda \
                            --region        ap-southeast-1

                        echo "✅ Lambda updated"
                    '''
                }
            }
        }

        // ── Stage 6: Verify Lambda ─────────────────────────────────
        stage('Verify Lambda') {
            steps {
                container('docker') {
                    sh '''
                        apk add --no-cache aws-cli python3

                        echo "🔍 Verifying Lambda deployment..."
                        aws lambda invoke \
                            --function-name aqi-prediction-lambda \
                            --region        ap-southeast-1 \
                            --payload       '{"body": "{\"T\": 25.0, \"H\": 60.0, \"P\": 1013.0, \"G\": 50000.0}"}' \
                            --cli-binary-format raw-in-base64-out \
                            /tmp/lambda_response.json

                        echo "📋 Lambda response:"
                        cat /tmp/lambda_response.json

                        python3 -c "
import json, sys
with open('/tmp/lambda_response.json') as f:
    resp = json.load(f)
status = resp.get('statusCode', 500)
if status != 200:
    print(f'statusCode={status}')
    sys.exit(1)
body = json.loads(resp.get('body', '{}'))
print(f'Verify passed | is_anomaly={body.get(\"is_anomaly\")} | score={body.get(\"decision_score\")}')
"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ DEPLOYMENT SUCCESSFUL | Image: ${env.IMAGE_TAG} | Lambda: aqi-prediction-lambda | Build: #${BUILD_NUMBER}"
        }
        failure {
            echo "❌ Pipeline failed — xem logs bên trên để debug"
        }
        always {
            sh "rm -f lambda/model.pkl lambda/scaler.pkl model.pkl scaler.pkl || true"
            echo "🧹 Workspace cleanup complete"
        }
    }
}
